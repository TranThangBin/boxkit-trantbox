FROM ghcr.io/tranthangbin/trantbox-base:latest

# Copy the setup scripts and package list
COPY ../scripts/trantbox-setup.sh /
COPY ../scripts/trantbox-cleanup.sh /
COPY ../scripts/trantbox-desktop.sh /
COPY ../packages/trantbox-desktop.packages /

# Run the setup scripts
RUN chmod +x trantbox-setup.sh trantbox-cleanup.sh trantbox-desktop.sh
RUN /trantbox-setup.sh

USER build
WORKDIR /home/build
RUN /trantbox-desktop.sh

USER root
WORKDIR /
RUN /trantbox-cleanup.sh
RUN rm /trantbox-setup.sh /trantbox-cleanup.sh /trantbox-desktop.sh /trantbox-desktop.packages


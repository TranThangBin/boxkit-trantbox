FROM docker.io/cachyos/cachyos-v3:latest

# Copy the setup scripts and package list
COPY ../scripts/trantbox-base.sh /
COPY ../scripts/distrobox-shims.sh /
COPY ../packages/trantbox-base.packages /

# Run the setup scripts
RUN chmod +x trantbox-base.sh distrobox-shims.sh && /trantbox-base.sh
RUN rm /trantbox-base.sh /distrobox-shims.sh /trantbox-base.packages

